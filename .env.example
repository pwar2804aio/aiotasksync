# Asana Personal Access Token
ASANA_TOKEN=your_asana_pat_here

# HubSpot Private App Token
# Required scopes: crm.objects.companies.read, crm.objects.deals.read, crm.objects.notes.write
HUBSPOT_TOKEN=your_hubspot_token_here

# JWT secret for session tokens (generate a random string)
JWT_SECRET=change-this-to-a-random-secret-string

# Admin credentials (set on first deploy, used to create the initial admin user)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-password

# Cron secret (Vercel auto-sets this, protects the auto-sync endpoint)
CRON_SECRET=
